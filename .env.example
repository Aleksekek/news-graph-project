# База данных
DB_HOST=localhost
DB_PORT=5432
DB_NAME=news_graph
DB_USER=postgres
DB_PASSWORD=your_password_here

# Парсеры
PARSER_REQUEST_DELAY=2.0
PARSER_MAX_RETRIES=3
PARSER_TIMEOUT=30

# Логирование
LOG_LEVEL=INFO
LOG_DIR=logs

# Телеграм (опционально)
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=your_chat_id_here
PROXY_URL=your_proxy_here (could be like ip:port:login:password)

# Время
TIMEZONE=Europe/Moscow