# =====================================================================
# Шаблон конфигурации. Скопируй в .env и подставь свои значения:
#     cp .env.example .env
# Все эти переменные читаются через src/config/settings.py (Pydantic).
# =====================================================================

# ── База данных ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=news_graph
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── LLM ──────────────────────────────────────────────────────────────
# Используется для суммаризации; для NER (если NER_ENGINE=llm);
# для weekly entity_cleanup (только в Natasha-режиме).
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── NER ──────────────────────────────────────────────────────────────
# Какой движок NER использовать:
#   natasha — локальный (sync, бесплатно, ниже качество)
#   llm     — DeepSeek API (async, ~$0.0001/статья, заметно лучше)
NER_ENGINE=natasha

# Размер батча и параллелизм внутри батча. Для llm имеет смысл concurrency 5+.
NER_BATCH_SIZE=100
NER_BATCH_CONCURRENCY=5

# ── Парсеры ─────────────────────────────────────────────────────────
PARSER_REQUEST_DELAY=2.0
PARSER_MAX_RETRIES=3
PARSER_TIMEOUT=30

# ── Логирование ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ── Telegram (опционально) ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=your_chat_id_here
# Формат: ip:port:login:password (или http://login:pass@ip:port)
PROXY_URL=your_proxy_here

# ── Время ───────────────────────────────────────────────────────────
TIMEZONE=Europe/Moscow
